{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "realm": "nutrify",
    "auth-server-url": "http://localhost:8080",
    "resource": "nutrify-api",
    "ssl-required": "none",
    "verify-token-audience": false
  }
}
